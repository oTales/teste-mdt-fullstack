{
  "_type": "export",
  "__exportFormat": 4,
  "__exportDate": "2026-04-01T00:00:00.000Z",
  "__exportSource": "insomnia.desktop",
  "resources": [
    {
      "_id": "wrk_ticket_mgmt",
      "_type": "workspace",
      "name": "Ticket Management API",
      "description": "API REST para Sistema de Gerenciamento de Tickets com Arquitetura DDD",
      "scope": "workspace"
    },
    {
      "_id": "env_dev",
      "_type": "environment",
      "parent": "wrk_ticket_mgmt",
      "name": "Development",
      "data": {
        "base_url": "http://localhost:8000/api",
        "token": "",
        "email": "joao@example.com",
        "password": "senha123456",
        "ticket_id": ""
      }
    },
    {
      "_id": "env_prod",
      "_type": "environment",
      "parent": "wrk_ticket_mgmt",
      "name": "Production",
      "data": {
        "base_url": "https://api.example.com",
        "token": "",
        "email": "",
        "password": "",
        "ticket_id": ""
      }
    },
    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parent": "wrk_ticket_mgmt",
      "name": "🔐 Autenticação"
    },
    {
      "_id": "req_register",
      "_type": "request",
      "parent": "fld_auth",
      "name": "Registrar Novo Usuário",
      "url": "{{ base_url }}/register",
      "method": "POST",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"password\": \"senha123456\"\n}"
      },
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parent": "fld_auth",
      "name": "Login de Usuário",
      "url": "{{ base_url }}/login",
      "method": "POST",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"{{ email }}\",\n  \"password\": \"{{ password }}\"\n}"
      },
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_me",
      "_type": "request",
      "parent": "fld_auth",
      "name": "Obter Usuário Atual",
      "url": "{{ base_url }}/me",
      "method": "GET",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_logout",
      "_type": "request",
      "parent": "fld_auth",
      "name": "Logout",
      "url": "{{ base_url }}/logout",
      "method": "POST",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "fld_tickets",
      "_type": "request_group",
      "parent": "wrk_ticket_mgmt",
      "name": "🎫 Tickets"
    },
    {
      "_id": "req_tickets_list",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Listar Todos os Tickets",
      "url": "{{ base_url }}/tickets",
      "method": "GET",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_tickets_paginated",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Listar Tickets (Paginado)",
      "url": "{{ base_url }}/tickets-paginated?page=1",
      "method": "GET",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_ticket_get",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Obter Ticket Específico",
      "url": "{{ base_url }}/tickets/{{ ticket_id }}",
      "method": "GET",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_ticket_create",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Criar Novo Ticket",
      "url": "{{ base_url }}/tickets",
      "method": "POST",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Bug no Sistema de Login\",\n  \"subject\": \"Usuários não conseguem fazer login\",\n  \"description\": \"Alguns usuários estão reportando que não conseguem fazer login no sistema. Quando tentam fazer login, recebem um erro genérico sem detalhes.\",\n  \"status\": 1,\n  \"priority\": 4\n}"
      },
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_ticket_update",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Atualizar Ticket",
      "url": "{{ base_url }}/tickets/{{ ticket_id }}",
      "method": "PATCH",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Bug no Sistema de Login - CRÍTICO\",\n  \"status\": 2,\n  \"priority\": 4\n}"
      },
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_ticket_delete",
      "_type": "request",
      "parent": "fld_tickets",
      "name": "Deletar Ticket",
      "url": "{{ base_url }}/tickets/{{ ticket_id }}",
      "method": "DELETE",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{ token }}"
        },
        {
          "name": "Accept",
          "value": "application/json"
        }
      ]
    }
  ]
}

